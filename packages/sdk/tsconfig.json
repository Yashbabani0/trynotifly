{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,
    "skipLibCheck": true,

    "declaration": true,

    "types": ["node"],

    "esModuleInterop": true,
    "resolveJsonModule": true
  },

  "include": ["./src/**/*.ts"]
}